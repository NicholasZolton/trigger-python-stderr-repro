+/**
+ * Build a base environment for Python subprocesses.
+ *
+ * Filters out OTEL_* variables from the parent process environment to prevent
+ * Python libraries (e.g. mlflow, opentelemetry-sdk) from picking them up and
+ * producing verbose debug output to stderr.  In the managed Trigger.dev runtime
+ * stderr is a blocking IPC socket with a ~208 KB buffer — exceeding that limit
+ * permanently deadlocks the subprocess.
+ */
+/**
+ * Eagerly start draining stdout/stderr from a tinyexec process.
+ *
+ * tinyexec defers `readStream()` until `_waitForOutput()` which only runs
+ * when the caller `await`s the result.  Between `spawn()` and that first
+ * `await` there is a microtask gap during which the subprocess can fill the
+ * pipe buffer (~64 KB on Linux) and block permanently.  Calling `.resume()`
+ * puts each stream into flowing mode so the kernel buffer is drained
+ * immediately, preventing the deadlock.
+ */
+function eagerDrain(proc: Result): Result {
+  const cp = proc.process;
+  cp?.stdout?.resume();
+  cp?.stderr?.resume();
+  return proc;
+}
+
+function buildPythonEnv(userEnv?: { [key: string]: string | undefined }): NodeJS.ProcessEnv {
+  const carrier = carrierFromContext();
+
+  const filteredEnv = Object.fromEntries(
+    Object.entries(process.env).filter(([key]) => !key.startsWith("OTEL_"))
+  );
+
+  return {
+    ...filteredEnv,
+    ...userEnv,
+    TRACEPARENT: carrier["traceparent"],
+    OTEL_RESOURCE_ATTRIBUTES: `${
+      SemanticInternalAttributes.EXECUTION_ENVIRONMENT
+    }=trigger,${Object.entries(taskContext.attributes)
+      .map(([key, value]) => `${key}=${value}`)
+      .join(",")}`,
+  };
+}
